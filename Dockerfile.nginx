# Build stage for web-app
FROM node:20-alpine AS web-app-builder

WORKDIR /app
COPY web-app/package*.json ./
RUN npm ci
COPY web-app/ ./
RUN npm run build

# Nginx stage
FROM nginx:alpine

COPY nginx.conf /etc/nginx/nginx.conf
COPY web-app.conf /etc/nginx/conf.d/default.conf
COPY --from=web-app-builder /app/dist/web-app/browser /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
